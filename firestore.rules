rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Profiles: Any authenticated user can read & write their own profile, and read others
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Matchmaking queue: Any authenticated user can queue themselves
    match /waiting_users/{userId} {
      allow read, write: if request.auth != null;
    }
    
    // Chat Rooms: Any authenticated user can read/write active private chat rooms
    match /chat_rooms/{roomId} {
      allow read, write: if request.auth != null;
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Public Group Chat Rooms: Any authenticated user can join, view, and chat in public channels
    match /public_rooms/{roomId} {
      allow read, write: if request.auth != null;
      
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }

      match /participants/{userId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Confessions: Any authenticated user can view, post, and interact with anonymous confessions
    match /confessions/{confessionId} {
      allow read, write: if request.auth != null;
    }
  }
}
